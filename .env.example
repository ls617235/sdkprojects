# ============================================
# SDK Share Platform - 环境变量配置
# 前后端分离架构
# ============================================
# 复制此文件为 .env 并填写实际值
# cp .env.example .env
# ============================================

# ==========================================
# 必需配置 - 外网数据库
# ==========================================

# PostgreSQL 数据库配置（必需）
# ⚠️ 必须使用外网数据库地址，禁止使用 localhost 或 127.0.0.1
DATABASE_URL=postgres://username:password@your-external-host:5432/sdk_share

# Redis 缓存配置（必需）
# ⚠️ 必须使用外网 Redis 地址，禁止使用 localhost 或 127.0.0.1
REDIS_URL=redis://:password@your-external-redis-host:6379/0

# ==========================================
# 前端配置
# ==========================================

# 前端端口
FRONTEND_PORT=3000

# 后端 API 地址（前端访问后端用）
NEXT_PUBLIC_API_URL=http://your-backend-host:8000

# ==========================================
# 后端配置
# ==========================================

# 后端端口
BACKEND_PORT=8000

# Worker 数量（建议 = CPU 核心数 * 2 + 1）
WORKERS=4

# 调试模式
DEBUG=false

# 数据库连接池
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# 缓存配置
CACHE_ENABLED=true
CACHE_TTL=300

# API 限流
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_PERIOD=60

# ==========================================
# 公网域名（用于生成嵌入代码）
# ==========================================
FRONTEND_DOMAIN=https://your-domain.com

# ==========================================
# Nginx 配置（生产环境）
# ==========================================
HTTP_PORT=80
HTTPS_PORT=443
