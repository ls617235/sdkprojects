# ============================================
# SDK Share Platform - Python Backend 配置
# ============================================

# 应用配置
APP_NAME=SDK Share API
APP_VERSION=1.0.0
DEBUG=false
ENVIRONMENT=production

# 服务器配置
HOST=0.0.0.0
PORT=8000
WORKERS=4

# 数据库配置 (PostgreSQL) - 必需
# 格式: postgres://用户名:密码@主机:端口/数据库名
DATABASE_URL=postgres://postgres:123456@127.0.0.1:5432/postgres

# 数据库连接池配置
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10
DATABASE_POOL_TIMEOUT=30

# Redis 缓存配置 - 必需使用外网 Redis
# ⚠️ 必须使用外网 Redis 地址，禁止使用 localhost 或 127.0.0.1
REDIS_URL=redis://:password@your-external-redis-host:6379/0
CACHE_TTL=300
CACHE_ENABLED=true

# API 限流配置
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_PERIOD=60

# CORS 配置
CORS_ORIGINS=["*"]
CORS_ALLOW_CREDENTIALS=true

# 前端域名（用于生成嵌入代码）
FRONTEND_DOMAIN=https://your-domain.com

# ============================================
# 灵童平台配置
# ============================================
# 灵童平台API地址
LINGTONG_BASE_URL=http://localhost:8800
# 灵童平台应用ID（可选）
LINGTONG_APP_ID=
# 灵童平台应用密钥（可选）
LINGTONG_APP_SECRET=
